{
  "name": "Google Sheets Integration Example",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3001/api/google/sheets/spreadsheets/YOUR_SPREADSHEET_ID/values/Sheet1!A1",
        "options": {},
        "bodyParametersJson": "={\n  \"userId\": \"YOUR_USER_ID\",\n  \"values\": [\n    [\"Timestamp\", \"Data\", \"Status\"],\n    [\"{{ $now.toISO() }}\", \"Test Data\", \"Success\"]\n  ]\n}"
      },
      "id": "http-request-append",
      "name": "Append to Google Sheets",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=http://localhost:3001/api/google/sheets/spreadsheets/YOUR_SPREADSHEET_ID/values/Sheet1!A1:C10?userId=YOUR_USER_ID",
        "options": {}
      },
      "id": "http-request-read",
      "name": "Read from Google Sheets",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [650, 300]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Append to Google Sheets",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Append to Google Sheets": {
      "main": [
        [
          {
            "node": "Read from Google Sheets",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {}
}
