{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "settings": {
    "react": {
      "version": "18.3"
    }
  },
  "rules": {
    "react/prop-types": "off",
    "no-unused-vars": "warn"
  },
  "ignorePatterns": ["dist/", "node_modules/", ".git/"]
}
